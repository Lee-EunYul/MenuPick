# 공통 환경변수 예시
# 이 파일을 복사해서 .env.local 로 이름을 바꾼 뒤 실제 값을 채워 넣으세요.

# ── 데이터베이스 ──────────────────────────────
# PostgreSQL 접속 주소
# 형식: postgresql://유저명:비밀번호@호스트:포트/DB이름
DATABASE_URL=postgresql://menupick_user:menupick_pass@localhost:5432/menupick_db

# ── 백엔드 서버 ───────────────────────────────
API_PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000
SHUTDOWN_TIMEOUT_MS=10000

# ── 프론트엔드 ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── 위치 기반 음식점 API ──────────────────────
# 카카오 REST API 키 (https://developers.kakao.com 에서 발급)
KAKAO_REST_API_KEY=여기에_카카오_API_키를_입력하세요
